rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each authenticated user (including anonymous) can read and write
    // ONLY their own document under /users/{uid}.
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly([
                        'created_at',
                        'last_updated',
                        'status',
                        'kidspark_word_unlocked',
                        'kidspark_emotional_unlocked',
                        'kidspark_problem_unlocked',
                        'kidspark_word_stars_1',
                        'kidspark_word_stars_2',
                        'kidspark_word_stars_3',
                        'kidspark_word_stars_4',
                        'kidspark_word_stars_5',
                        'kidspark_emotional_stars_1',
                        'kidspark_emotional_stars_2',
                        'kidspark_emotional_stars_3',
                        'kidspark_emotional_stars_4',
                        'kidspark_emotional_stars_5',
                        'kidspark_problem_stars_1',
                        'kidspark_problem_stars_2',
                        'kidspark_problem_stars_3',
                        'kidspark_problem_stars_4',
                        'kidspark_problem_stars_5'
                      ]);
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
